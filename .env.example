
# LinkedIn
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_COOKIES_PATH=./config/linkedin_cookies.json

# Database
DATABASE_URL=postgresql://autoapply:autoapply@localhost:5432/autoapply
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=ap-south-1
AWS_PROFILE=default
S3_BUCKET=autoapply-your-name
SNS_ALERT_EMAIL=

# Deployment
DEPLOY_TARGET=local

# Proxy
PROXY_LIST=

# Applier safety
APPLIER_DRY_RUN=true
MAX_DAILY_APPLIES=40
APPLIER_ANSWER_MODE=local

# AWS SSH test target - optional, keep prod services untouched
AWS_SSH_HOST=
AWS_SSH_USER=
AWS_SSH_KEY_PATH=
AWS_REMOTE_PROJECT_DIR=/tmp/autoapply-codex-test
AWS_PROD_TEST_DIR=/home/ubuntu/autoapply-prod-test
